# Required (see former application.properties keys)
WEBIO_URL=http://1.2.3.4/Single
THINGSPEAK_API_URL=https://api.thingspeak.com/update
THINGSPEAK_API_KEY=<key>
PEGEL_API_BASE_URL=https://pegel.fw-murrhardt.de
PEGEL_API_KEY=<key>

# Optional: working directory for ./logs/app.log (default: current directory)
# LOG_DIR=.

# Optional: 6-field cron (seconds first), e.g. every 5 minutes at second 0 (default)
# SCHEDULE_CRON=0 */5 * * * *

# Optional: slog level — debug, info, warn, error (default: info)
# LOG_LEVEL=info
